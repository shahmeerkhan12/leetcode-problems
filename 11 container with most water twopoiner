class Solution:
    def maxArea(self, height: List[int]) -> int:
        
        l,r = 0, len(height)-1
        maxA = 0

        while l<r:

            width = r-l
            length = min(height[l],height[r])
            area = length * width

            maxA = max(maxA,area)

            if height[l] < height[r]:
                l += 1
            else:
                r -= 1

        return maxA
